{
  "daemon": true,
  "run": [
    {
      "method": "shell.run",
      "params": {
        "venv": "env",
        "path": "app",
        "message": "python resemble-enhance/app.py",
        "on": [
          {
            "event": "/http:\\/\\/\\S+/",
            "done": true
          }
        ]
      }
    }
  ]
}