{
  "daemon": true,
  "run": [
    {
      "method": "shell.run",
      "params": {
        "venv": "env",
        "path": "app",
        "message": "{{exists('app/resemble-enhance/app.py') ? 'cd resemble-enhance && python app.py' : 'python app.py'}}",
        "on": [
          {
            "event": "/(http:\\/\\/[0-9.:]+)/",
            "done": true
          }
        ]
      }
    },
    {
      "method": "local.set",
      "params": {
        "url": "{{input.event[1]}}"
      }
    }
  ]
}
