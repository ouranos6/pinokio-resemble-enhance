{
  "run": [
    {
      "when": "{{exists('app') && !exists('app/app.py') && !exists('app/resemble-enhance/app.py')}}",
      "method": "fs.rm",
      "params": {
        "path": "app"
      }
    },
    {
      "when": "{{!exists('app')}}",
      "method": "shell.run",
      "params": {
        "message": "git submodule add https://github.com/resemble-ai/resemble-enhance.git app/ && git submodule init && git submodule sync --recursive",
        "path": "."
      }
    },
    {
      "when": "{{exists('app/resemble-enhance/app.py')}}",
      "method": "fs.copy",
      "params": {
        "src": "patches/app.py",
        "dest": "app/resemble-enhance/app.py"
      }
    },
    {
      "when": "{{exists('app/app.py')}}",
      "method": "fs.copy",
      "params": {
        "src": "patches/app.py",
        "dest": "app/app.py"
      }
    },
    {
      "when": "{{exists('app/resemble-enhance/resemble_enhance')}}",
      "method": "fs.copy",
      "params": {
        "src": "patches/resemble_enhance/enhancer/inference.py",
        "dest": "app/resemble-enhance/resemble_enhance/enhancer/inference.py"
      }
    },
    {
      "when": "{{exists('app/resemble_enhance')}}",
      "method": "fs.copy",
      "params": {
        "src": "patches/resemble_enhance/enhancer/inference.py",
        "dest": "app/resemble_enhance/enhancer/inference.py"
      }
    },
    {
      "when": "{{exists('app/resemble-enhance/resemble_enhance')}}",
      "method": "fs.copy",
      "params": {
        "src": "patches/resemble_enhance/denoiser/inference.py",
        "dest": "app/resemble-enhance/resemble_enhance/denoiser/inference.py"
      }
    },
    {
      "when": "{{exists('app/resemble_enhance')}}",
      "method": "fs.copy",
      "params": {
        "src": "patches/resemble_enhance/denoiser/inference.py",
        "dest": "app/resemble_enhance/denoiser/inference.py"
      }
    },
    {
      "when": "{{exists('app/resemble-enhance/resemble_enhance')}}",
      "method": "fs.copy",
      "params": {
        "src": "patches/resemble_enhance/utils/distributed.py",
        "dest": "app/resemble-enhance/resemble_enhance/utils/distributed.py"
      }
    },
    {
      "when": "{{exists('app/resemble_enhance')}}",
      "method": "fs.copy",
      "params": {
        "src": "patches/resemble_enhance/utils/distributed.py",
        "dest": "app/resemble_enhance/utils/distributed.py"
      }
    },
    {
      "when": "{{exists('app/resemble-enhance/resemble_enhance')}}",
      "method": "fs.copy",
      "params": {
        "src": "patches/resemble_enhance/utils/__init__.py",
        "dest": "app/resemble-enhance/resemble_enhance/utils/__init__.py"
      }
    },
    {
      "when": "{{exists('app/resemble_enhance')}}",
      "method": "fs.copy",
      "params": {
        "src": "patches/resemble_enhance/utils/__init__.py",
        "dest": "app/resemble_enhance/utils/__init__.py"
      }
    },
    {
      "when": "{{exists('app/resemble-enhance/resemble_enhance')}}",
      "method": "fs.copy",
      "params": {
        "src": "patches/resemble_enhance/enhancer/enhancer.py",
        "dest": "app/resemble-enhance/resemble_enhance/enhancer/enhancer.py"
      }
    },
    {
      "when": "{{exists('app/resemble_enhance')}}",
      "method": "fs.copy",
      "params": {
        "src": "patches/resemble_enhance/enhancer/enhancer.py",
        "dest": "app/resemble_enhance/enhancer/enhancer.py"
      }
    },
    {
      "when": "{{exists('app/resemble-enhance/resemble_enhance')}}",
      "method": "fs.copy",
      "params": {
        "src": "patches/resemble_enhance/enhancer/lcfm/cfm.py",
        "dest": "app/resemble-enhance/resemble_enhance/enhancer/lcfm/cfm.py"
      }
    },
    {
      "when": "{{exists('app/resemble_enhance')}}",
      "method": "fs.copy",
      "params": {
        "src": "patches/resemble_enhance/enhancer/lcfm/cfm.py",
        "dest": "app/resemble_enhance/enhancer/lcfm/cfm.py"
      }
    },
    {
      "when": "{{exists('app/resemble-enhance/resemble_enhance')}}",
      "method": "fs.copy",
      "params": {
        "src": "patches/resemble_enhance/enhancer/lcfm/lcfm.py",
        "dest": "app/resemble-enhance/resemble_enhance/enhancer/lcfm/lcfm.py"
      }
    },
    {
      "when": "{{exists('app/resemble_enhance')}}",
      "method": "fs.copy",
      "params": {
        "src": "patches/resemble_enhance/enhancer/lcfm/lcfm.py",
        "dest": "app/resemble_enhance/enhancer/lcfm/lcfm.py"
      }
    },
    {
      "method": "script.start",
      "params": {
        "uri": "torch.js",
        "params": {
          "venv": "env",
          "path": "app"
        }
      }
    },
    {
      "method": "shell.run",
      "params": {
        "venv": "env",
        "path": "app/resemble-enhance",
        "message": [
          "{{exists('requirements.txt') ? 'uv pip install -r requirements.txt gradio' : 'uv pip install torch torchaudio librosa scipy rich pandas deepspeed gradio'}}",
          "{{(exists('pyproject.toml') || exists('setup.py')) ? 'uv pip install -e .' : 'echo Skipping editable install (no pyproject.toml/setup.py found)')}}"
        ]
      }
    }
  ]
}
