{
  "run": [
    {
      "when": "{{!exists('app')}}",
      "method": "shell.run",
      "params": {
        "message": "git clone --depth 1 https://github.com/resemble-ai/resemble-enhance.git app",
        "path": "."
      }
    },
    {
      "method": "script.start",
      "params": {
        "uri": "torch.js",
        "params": {
          "venv": "env",
          "path": "app"
        }
      }
    },
    {
      "method": "shell.run",
      "params": {
        "venv": "env",
        "path": "app",
        "message": [
          "uv pip install -r requirements.txt gradio",
          "uv pip install -e ."
        ]
      }
    }
  ]
}
