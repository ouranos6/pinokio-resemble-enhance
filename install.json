{
  "run": [
    {
      "when": "{{exists('app') && !exists('app/app.py')}}",
      "method": "fs.rm",
      "params": { "path": "app" }
    },
    {
      "when": "{{!exists('app')}}",
      "method": "shell.run",
      "params": {
        "message": "git clone https://github.com/resemble-ai/resemble-enhance.git app && git -C app submodule update --init --recursive",
        "path": "."
      }
    },
    {
      "when": "{{exists('app/app.py')}}",
      "method": "fs.copy",
      "params": { "src": "patches/app.py", "dest": "app/app.py" }
    },
    {
      "when": "{{exists('app/resemble_enhance')}}",
      "method": "fs.copy",
      "params": { "src": "patches/resemble_enhance/enhancer/inference.py", "dest": "app/resemble_enhance/enhancer/inference.py" }
    },
    {
      "when": "{{exists('app/resemble_enhance')}}",
      "method": "fs.copy",
      "params": { "src": "patches/resemble_enhance/denoiser/inference.py", "dest": "app/resemble_enhance/denoiser/inference.py" }
    },
    {
      "when": "{{exists('app/resemble_enhance')}}",
      "method": "fs.copy",
      "params": { "src": "patches/resemble_enhance/utils/distributed.py", "dest": "app/resemble_enhance/utils/distributed.py" }
    },
    {
      "when": "{{exists('app/resemble_enhance')}}",
      "method": "fs.copy",
      "params": { "src": "patches/resemble_enhance/utils/__init__.py", "dest": "app/resemble_enhance/utils/__init__.py" }
    },
    {
      "when": "{{exists('app/resemble_enhance')}}",
      "method": "fs.copy",
      "params": { "src": "patches/resemble_enhance/enhancer/enhancer.py", "dest": "app/resemble_enhance/enhancer/enhancer.py" }
    },
    {
      "when": "{{exists('app/resemble_enhance')}}",
      "method": "fs.copy",
      "params": { "src": "patches/resemble_enhance/enhancer/lcfm/cfm.py", "dest": "app/resemble_enhance/enhancer/lcfm/cfm.py" }
    },
    {
      "when": "{{exists('app/resemble_enhance')}}",
      "method": "fs.copy",
      "params": { "src": "patches/resemble_enhance/enhancer/lcfm/lcfm.py", "dest": "app/resemble_enhance/enhancer/lcfm/lcfm.py" }
    },
    {
      "method": "script.start",
      "params": { "uri": "torch.js", "params": { "venv": "env", "path": "app" } }
    },
    {
      "method": "shell.run",
      "params": {
        "venv": "env",
        "path": "app",
        "message": [
          "uv pip install \"celluloid>=0.2.0\" \"librosa>=0.10.1\" \"matplotlib>=3.8.1\" \"numpy>=1.26.2\" \"omegaconf>=2.3.0\" \"pandas>=2.1.3\" \"ptflops>=0.7.1.2\" \"rich>=13.7.0\" \"scipy>=1.11.4\" \"soundfile>=0.12.1\" \"tqdm>=4.66.1\" \"resampy>=0.4.2\" \"tabulate>=0.8.10\" \"gradio>=4.8.0\"",
          "{{exists('app/pyproject.toml') ? 'uv pip install -e . --no-deps' : 'echo Skipping editable install (no pyproject.toml found)'}}"
        ]
      }
    }
  ]
}
