{
  "run": [
    {
      "method": "shell.run",
      "params": {
        "message": "git -C app pull --ff-only",
        "path": "."
      }
    },
    {
      "method": "shell.run",
      "params": {
        "venv": "env",
        "path": "app",
        "message": [
          "uv pip install -r requirements.txt",
          "uv pip install -e ."
        ]
      }
    }
  ]
}
